case 4:
{
    double a, b, c;
    double tol = 0.000001;      // Eeste es el rror permitido
    int iter = 0;
    int max_iter = 100;
    int decimales;

    cout << "**------- AGENDA INTELIGENTE -------**\n";

    cout << "Ingrese la hora inicial disponible: ";
    cin >> a;
    cout << "Ingrese la hora final disponible: ";
    cin >> b;

    // Verifica que el intervalo sea válido de forma lógica
    if (a >= b)
    {
        cout << "\nLa hora inicial debe ser menor que la hora final.\n";
        break;
    }

    // control clinico previo: Si la hora exacta inicial ya es perfecta ( es la raíz)
    if (fabs(f(a)) < tol) 
    {
        // Ajusta levemente el extremo para obligar a los codigos a rpetir en un entorno aceptado   
        a += 0.1; 
    }
    // Si la hora exacta final ya es perfecta (raíz)
    if (fabs(f(b)) < tol) 
    {
        b -= 0.1;
    }

    // se hace un cambion de signo real en sus extremos para trabajar
    if (f(a) * f(b) > 0)
    {
        cout << "\nNo fue posible analizar el intervalo ingresado." << endl;
        cout << "Intente nuevamente con un rango de horas diferente (ej: 1 a 3)." << endl;
        break;
    }

    // -----------------------------------------------------
    // Se integra el metodo de biseccion
    // Funcion: Localizar un espacio optimo dividiendo de forma
    // simetrica las horas libres en la agenda de la clinica
    // -----------------------------------------------------
    cout << "\nAnalizando disponibilidad de horarios..." << endl;

    double tpA = a;
    double tpB = b;
    iter = 0;

    while (fabs(tpB - tpA) > tol && iter < max_iter)
    {
        c = (tpA + tpB) / 2.0;
        if (fabs(f(c)) < tol)
            break;
        if (f(tpA) * f(c) < 0)
            tpB = c;
        else
            tpA = c;
        iter++;
    }

    double horarioPrincipal = c;

    // -----------------------------------------------------
    // se implementa el metodo de la falfa posicion
    // Funcion: Encontrar el hueco en la agenda con mayor velocidad, 
    // ponderando la disponibilidad por peso de importancia
    // -----------------------------------------------------
    cout << "Buscando una alternativa de horario..." << endl;

    tpA = a;
    tpB = b;
    iter = 0;

    while (iter < max_iter)
    {
        if (fabs(f(tpB) - f(tpA)) < 1e-10) break; // Evita división por cero
        c = (tpA * f(tpB) - tpB * f(tpA)) / (f(tpB) - f(tpA));
        if (fabs(f(c)) < tol)
            break;
        if (f(tpA) * f(c) < 0)
            tpB = c;
        else
            tpA = c;
        iter++;
    }

    double horarioAlternativo = c;

    // -----------------------------------------------------
    // Aqui se incluye cifras significativa / decimales
    // Funcion: Ajustar esteticamente el bloque horario final
    // para que muestre solo los digitos legibles del reporte
    // -----------------------------------------------------
    cout << "\nCantidad de decimales para mostrar el horario: ";
    cin >> decimales;

    cout.setf(ios::fixed);
    cout.precision(decimales);

    cout << "\n**------------------------------------**" << endl;
    cout << "        HORARIOS RECOMENDADOS" << endl;
    cout << "**--------------------------------------**" << endl;
    cout << "Horario recomendado (Biseccion)       : " << horarioPrincipal << " hrs" << endl;
    cout << "Horario alternativo (Falsa Posicion)  : " << horarioAlternativo << " hrs" << endl;
    cout << "**--------------------------------------**" << endl;

    cout.unsetf(ios::fixed);
    break;
}

